{
  "manifest_version": 3,
  "name": "Screen Recorder",
  "version": "1.0",
  "description": "Record screen + webcam bubble + audio. Save to desktop.",
  "permissions": [
    "activeTab",
    "scripting",
    "downloads"
  ],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Screen Recorder",
    "default_icon": { "128": "icon.png" }
  },
  "icons": { "128": "icon.png" },
  "web_accessible_resources": [{
    "resources": ["teleprompter.html", "teleprompter.js"],
    "matches": ["<all_urls>"]
  }]
}
